# Server Configuration
PORT=3002

# Tesseract OCR Configuration
# Override the Tesseract binary path if the auto-detected default is wrong for your OS.
# Default locations used when this variable is not set:
#   macOS (Homebrew ARM):   /opt/homebrew/bin/tesseract
#   macOS (Homebrew Intel): /usr/local/bin/tesseract
#   Linux:                  /usr/bin/tesseract
#   Windows:                C:\Program Files\Tesseract-OCR\tesseract.exe
# TESSERACT_CMD=/custom/path/to/tesseract

# ChromaDB Storage Path (default: ./chroma_db)
# CHROMA_DB_PATH=./chroma_db

# CORS Allowed Origin (default: * — restrict in production)
# ALLOWED_ORIGIN=https://your-frontend-domain.com
